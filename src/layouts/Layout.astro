---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Good News Community Education Centre — CBC primary school in Kahawa Wendani, Nairobi. Quality, affordable education for PP1 to Grade 6. MoE registered." } = Astro.props;
const pageTitle = `${title} | Good News CEC — CBC Primary School Kahawa Wendani`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="Good News CEC, CBC primary school, Kahawa Wendani, Nairobi school, PP1 Grade 6, affordable school Kenya, MoE registered school" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://wendani-school.vercel.app" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/logo.png" />
    <meta property="og:locale" content="en_KE" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- Google Fonts: Lexend + Source Sans 3 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;600;700;800&family=Source+Sans+3:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />

    <!-- Styles -->
    <link rel="stylesheet" href="/styles/global.css" />
    <link rel="stylesheet" href="/styles/navbar.css" />
    <link rel="stylesheet" href="/styles/hero.css" />
    <link rel="stylesheet" href="/styles/trust-bar.css" />
    <link rel="stylesheet" href="/styles/features.css" />
    <link rel="stylesheet" href="/styles/programs.css" />
    <link rel="stylesheet" href="/styles/animations.css" />
    <link rel="stylesheet" href="/styles/headteacher.css" />
    <link rel="stylesheet" href="/styles/cta.css" />
    <link rel="stylesheet" href="/styles/footer.css" />
    <link rel="stylesheet" href="/styles/page-header.css" />
    <link rel="stylesheet" href="/styles/about.css" />
    <link rel="stylesheet" href="/styles/admissions.css" />
    <link rel="stylesheet" href="/styles/contact.css" />
  </head>
  <body style="background-color:#ffffff">
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
