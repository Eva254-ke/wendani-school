---
// Trust Bar Component
---

<section class="trust-bar" aria-label="School trust highlights">
  <div class="trust-bar__container">
    <div class="trust-bar__intro fade-in-section">
      <span class="trust-bar__eyebrow">Quick facts</span>
      <h2 class="trust-bar__heading">A school where potential blossoms and parents can stay connected.</h2>
    </div>

    <div class="trust-bar__grid">
      <article class="trust-bar__item trust-bar__item--location fade-in-section stagger-1">
        <div class="trust-bar__icon-wrap" aria-hidden="true">
          <svg class="trust-bar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
        </div>
        <div class="trust-bar__body">
          <p class="trust-bar__kicker">Location</p>
          <h3 class="trust-bar__title">Kahawa Wendani</h3>
          <p class="trust-bar__text">About 100m behind Cleanshelf Supermarket.</p>
        </div>
      </article>

      <article class="trust-bar__item trust-bar__item--registered fade-in-section stagger-2">
        <div class="trust-bar__icon-wrap" aria-hidden="true">
          <svg class="trust-bar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3l7 3v5c0 4.55-2.9 8.58-7 10-4.1-1.42-7-5.45-7-10V6l7-3z"></path>
            <path d="M9 12l2 2 4-5"></path>
          </svg>
        </div>
        <div class="trust-bar__body">
          <p class="trust-bar__kicker">Recognition</p>
          <h3 class="trust-bar__title">MoE Registered</h3>
          <p class="trust-bar__text">Officially recognised by the Ministry of Education.</p>
        </div>
      </article>

      <article class="trust-bar__item trust-bar__item--call fade-in-section stagger-3">
        <div class="trust-bar__icon-wrap" aria-hidden="true">
          <svg class="trust-bar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
          </svg>
        </div>
        <div class="trust-bar__body">
          <p class="trust-bar__kicker">Admissions desk</p>
          <h3 class="trust-bar__title"><a href="tel:+254722420147">0722 420 147</a></h3>
          <p class="trust-bar__text">Call or WhatsApp for visits and enrollment.</p>
        </div>
      </article>
    </div>
  </div>
</section>

<script>
  const trustObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        trustObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  const initTrustBarAutoScroll = () => {
    const rail = document.querySelector('.trust-bar__grid');
    const items = rail ? Array.from(rail.querySelectorAll('.trust-bar__item')) : [];
    const mobileQuery = window.matchMedia('(max-width: 767px)');
    const reducedMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    let timer;
    let pauseUntil = 0;

    const stop = () => {
      if (timer) window.clearInterval(timer);
      timer = undefined;
    };

    const start = () => {
      stop();
      if (!rail || items.length < 2 || !mobileQuery.matches || reducedMotionQuery.matches) return;

      timer = window.setInterval(() => {
        if (Date.now() < pauseUntil) return;

        const currentIndex = items.reduce((closestIndex, item, index) => {
          const currentDistance = Math.abs(item.offsetLeft - rail.scrollLeft);
          const closestDistance = Math.abs(items[closestIndex].offsetLeft - rail.scrollLeft);
          return currentDistance < closestDistance ? index : closestIndex;
        }, 0);
        const nextItem = items[(currentIndex + 1) % items.length];

        rail.scrollTo({ left: nextItem.offsetLeft, behavior: 'smooth' });
      }, 3200);
    };

    const pause = () => {
      pauseUntil = Date.now() + 6500;
    };

    rail?.addEventListener('pointerdown', pause, { passive: true });
    rail?.addEventListener('touchstart', pause, { passive: true });
    rail?.addEventListener('focusin', pause);
    mobileQuery.addEventListener('change', start);
    reducedMotionQuery.addEventListener('change', start);
    start();
  };

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.trust-bar .fade-in-section').forEach(el => trustObserver.observe(el));
    initTrustBarAutoScroll();
  });
</script>



