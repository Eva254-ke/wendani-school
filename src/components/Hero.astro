      <div class="hero__stats">
        <div class="hero__stat">
          <div class="hero__stat-value">CBC</div>
          <div class="hero__stat-label">Curriculum</div>
        </div>
        <div class="hero__stat">
          <div class="hero__stat-value">PP1–Gr.6</div>
          <div class="hero__stat-label">All Levels</div>
        </div>
        <div class="hero__stat">
          <div class="hero__stat-value">MoE</div>
          <div class="hero__stat-label">Registered</div>
        </div>
