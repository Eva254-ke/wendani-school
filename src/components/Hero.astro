      <p class="hero__subtitle">
        Quality, affordable, and values-based primary education.
        A safe, welcoming place for your child to learn, grow, and thrive.
      </p>

      <div class="hero__actions">
        <a href="/admissions" class="btn btn--primary">View Admissions</a>
        <a href="https://wa.me/254722420147" class="btn btn--whatsapp" target="_blank" rel="noopener noreferrer">
