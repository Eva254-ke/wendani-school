---
// Features Section - Two Column Alternating Layout
---

<section class="features">
  <div class="features__container">
    
    <div class="features__header fade-in-section">
      <span class="section-label">Why Choose Us</span>
      <h2 class="features__title">Why Choose Good News CEC?</h2>
      <p class="features__subtitle">We provide a nurturing environment where every child can reach their full potential</p>
    </div>

    <!-- Feature 1: CBC Curriculum -->
    <div class="feature-row fade-in-section">
      <div class="feature-row__content">
        <h3 class="feature-row__title">CBC Curriculum Excellence</h3>
        <p class="feature-row__text">
          We follow the Competency-Based Curriculum (CBC) that focuses on developing practical skills, creativity, and critical thinking in every learner.
        </p>
        <ul class="feature-row__list">
          <li class="feature-row__list-item">
            <span class="feature-row__list-icon" aria-hidden="true"></span>
            <span>Hands-on learning activities</span>
          </li>
          <li class="feature-row__list-item">
            <span class="feature-row__list-icon" aria-hidden="true"></span>
            <span>Talents and interests development</span>
          </li>
          <li class="feature-row__list-item">
            <span class="feature-row__list-icon" aria-hidden="true"></span>
            <span>Trained and dedicated teachers</span>
          </li>
        </ul>
      </div>
      <div class="feature-row__image-wrapper">
        <img src="/images/cbc-curriculum-excellence.jpeg" alt="Good News CEC students engaged in CBC learning activities" class="feature-row__image" />
      </div>
    </div>

    <!-- Feature 2: Safe Environment -->
    <div class="feature-row feature-row--reverse fade-in-section">
      <div class="feature-row__content">
        <h3 class="feature-row__title">Safe & Nurturing Environment</h3>
        <p class="feature-row__text">
          Your child's safety and well-being are our top priorities. We maintain a secure, clean, and supportive learning environment.
        </p>
        <ul class="feature-row__list">
          <li class="feature-row__list-item">
            <span class="feature-row__list-icon" aria-hidden="true"></span>
            <span>Secure school compound with fencing</span>
          </li>
          <li class="feature-row__list-item">
            <span class="feature-row__list-icon" aria-hidden="true"></span>
            <span>Caring and trained teaching staff</span>
          </li>
          <li class="feature-row__list-item">
            <span class="feature-row__list-icon" aria-hidden="true"></span>
            <span>Anti-bullying policies enforced</span>
          </li>
        </ul>
      </div>
      <div class="feature-row__image-wrapper">
        <img src="/images/safe-nurturing-playground.jpeg" alt="Good News CEC children playing in the school playground" class="feature-row__image" />
      </div>
    </div>

    <!-- Feature 3: Affordable Fees -->
    <div class="feature-row fade-in-section">
      <div class="feature-row__content">
        <h3 class="feature-row__title">Affordable & Transparent Fees</h3>
        <p class="feature-row__text">
          Quality education should be accessible. We offer competitive fees with flexible payment plans to support our community families.
        </p>
        <ul class="feature-row__list">
          <li class="feature-row__list-item">
            <span class="feature-row__list-icon" aria-hidden="true"></span>
            <span>Competitive pricing for quality education</span>
          </li>
          <li class="feature-row__list-item">
            <span class="feature-row__list-icon" aria-hidden="true"></span>
            <span>Flexible payment plans available</span>
          </li>
          <li class="feature-row__list-item">
            <span class="feature-row__list-icon" aria-hidden="true"></span>
            <span>No hidden charges - full transparency</span>
          </li>
        </ul>
      </div>
      <div class="feature-row__image-wrapper">
        <img src="https://scontent-mba2-1.xx.fbcdn.net/v/t39.30808-6/605540854_801476866275066_1196829343275411935_n.jpg?stp=dst-jpg_tt6&amp;cstp=mx1536x2048&amp;ctp=s1536x2048&amp;_nc_cat=104&amp;ccb=1-7&amp;_nc_sid=833d8c&amp;_nc_eui2=AeHnmw6NivFgtKIZKscRPzjcfcS7p621kJp9xLunrbWQmuv5QxCn4eBGnb5YzvsSqVIuU3UcZw3-6Ipnb1Z38v84&amp;_nc_ohc=YlvUXm-wGpIQ7kNvwFlvjvC&amp;_nc_oc=AdqAb3h9lT0qQVydeQfHW61u4bAtiDf8YxNP_QLF8f7EQL4v_5FmYQGMggXvXKtbWSc&amp;_nc_zt=23&amp;_nc_ht=scontent-mba2-1.xx&amp;_nc_gid=a5GvmoDZHE3ybr6qv8JpSA&amp;_nc_ss=7b2a8&amp;oh=00_AQBKNhbG4u2fIeHsWVGcTN4SMkge-GQ7OZsWfUMgKUxheg&amp;oe=6A61300F" alt="School activities and events" class="feature-row__image" />
      </div>
    </div>

  </div>
</section>

<script>
  // Intersection Observer for fade-in animation
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.addEventListener('DOMContentLoaded', () => {
    const sections = document.querySelectorAll('.fade-in-section');
    sections.forEach(section => {
      observer.observe(section);
    });
  });
</script>
