---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Admissions">
  <PageHeader 
    title="Admissions" 
    subtitle="Join the Good News CEC family. Our enrollment process is simple, transparent, and designed to welcome your child."
  />

  <section class="admissions-section">
    <div class="admissions__container">
      
      <!-- Steps -->
      <div class="admissions__step fade-in-section">
        <div class="admissions__step-number">1</div>
        <div class="admissions__step-content">
          <h3>Schedule a School Visit</h3>
          <p>Come see our facilities, meet our teachers, and experience the Good News CEC environment firsthand. Call us or message on WhatsApp to book a tour.</p>
        </div>
      </div>

      <div class="admissions__step fade-in-section stagger-1">
        <div class="admissions__step-number">2</div>
        <div class="admissions__step-content">
          <h3>Submit Application & Documents</h3>
          <p>Fill out the admission form available at the school office. Submit a copy of the child's birth certificate, previous school reports (if transferring), and 2 passport photos.</p>
        </div>
      </div>

      <div class="admissions__step fade-in-section stagger-2">
        <div class="admissions__step-number">3</div>
        <div class="admissions__step-content">
          <h3>Assessment & Enrollment</h3>
          <p>A brief, friendly assessment is conducted to understand the child's learning level. Upon approval, pay the admission fee to secure the child's place for the term.</p>
        </div>
      </div>

      <!-- Requirements Box -->
      <div class="admissions__requirements fade-in-section">
        <h3>Required Documents</h3>
        <ul class="admissions__list">
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Original and copy of the child's Birth Certificate</span>
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>2 recent passport-sized photographs</span>
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Previous school report forms (for transfers)</span>
          </li>
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Parent/Guardian National ID copy</span>
          </li>
        </ul>
        <div style="margin-top: 2rem; text-align: center;">
          <a href="/contact" class="btn btn--primary">Contact Us to Start</a>
        </div>
      </div>

    </div>
  </section>

  <Footer />
</Layout>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.fade-in-section').forEach(el => observer.observe(el));
  });
</script>