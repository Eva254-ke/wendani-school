---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Us">
  <PageHeader 
    title="About Good News CEC" 
    subtitle="Dedicated to providing quality, values-based education to the Kahawa Wendani community since our establishment."
  />

  <section class="about-section">
    <div class="about__container">
      <div class="about__grid">
        
        <!-- Mission -->
        <div class="about__card fade-in-section">
          <div class="about__card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="16" x2="12" y2="12"></line>
              <line x1="12" y1="8" x2="12.01" y2="8"></line>
            </svg>
          </div>
          <h3 class="about__card-title">Our Mission</h3>
          <p class="about__card-text">
            To provide accessible, high-quality, and holistic education that empowers children to become confident, compassionate, and responsible members of society.
          </p>
        </div>

        <!-- Vision -->
        <div class="about__card fade-in-section stagger-1">
          <div class="about__card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
          </div>
          <h3 class="about__card-title">Our Vision</h3>
          <p class="about__card-text">
            To be the leading community primary school in Kahawa Wendani, recognized for academic excellence, strong moral values, and nurturing every child's unique potential.
          </p>
        </div>

        <!-- Core Values -->
        <div class="about__card fade-in-section stagger-2">
          <div class="about__card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
            </svg>
          </div>
          <h3 class="about__card-title">Core Values</h3>
          <p class="about__card-text">
            Integrity, Discipline, Excellence, Compassion, and Community. We believe these pillars shape not just good students, but great human beings.
          </p>
        </div>

      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  // Re-use the same intersection observer logic for fade-in
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.fade-in-section').forEach(el => observer.observe(el));
  });
</script>