---
// Headteacher Welcome Section
---

<section class="headteacher">
  <div class="headteacher__container">
    <div class="headteacher__grid">
      
      <!-- Photo -->
      <div class="headteacher__photo-wrapper fade-in-section">
        <div class="headteacher__photo-container">
          <img src="https://scontent-mba2-1.xx.fbcdn.net/v/t39.30808-6/482319588_566365986452823_4200108469152857284_n.jpg?stp=dst-jpg_tt6&amp;cstp=mx2048x922&amp;ctp=s2048x922&amp;_nc_cat=100&amp;ccb=1-7&amp;_nc_sid=833d8c&amp;_nc_eui2=AeFuZMjV2oyx_N5XexQD8MxlQrc1zOpOI_RCtzXM6k4j9A2iXMLxeItkYffPsknXJneQDirXMonKQWPmhE_78J_n&amp;_nc_ohc=2dcg5UKkWGcQ7kNvwHxzL-k&amp;_nc_oc=AdqoKevXZm7ZQEHmAq968BEM-BQXgatrj6ARFDOrl2j1ca3WGgO6WrJJlLPMm_-EAYA&amp;_nc_zt=23&amp;_nc_ht=scontent-mba2-1.xx&amp;_nc_gid=eidDGXE04Ytz772sPLo4kw&amp;_nc_ss=7b2a8&amp;oh=00_AQCRgLGgIJMDH3Ahkq5kldi6qSB_KC6IsmYVncbZZYQmYA&amp;oe=6A6120C2" alt="Headteacher" class="headteacher__photo" />
          <p class="headteacher__photo-text">Photo: Headteacher<br/>Replace with actual photo</p>
        </div>
      </div>

      <!-- Content -->
      <div class="headteacher__content fade-in-section stagger-1">
        <span class="headteacher__badge">Message from Leadership</span>
        <div class="divider"></div>
        <h2 class="headteacher__title">Welcome to Good News Community Education Centre</h2>
        <blockquote class="headteacher__quote">
          "At Good News CEC, we believe every child has unique potential waiting to be discovered. Our commitment is to provide a nurturing, safe, and academically excellent environment where your child can grow into a confident, compassionate, and capable individual. We don't just teach curriculum—we build character, foster creativity, and prepare our students for a bright future."
        </blockquote>
        <div class="headteacher__signature">
          <p class="headteacher__name">Simon Kilonzo</p>
          <p class="headteacher__position">Headteacher, Good News CEC</p>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.addEventListener('DOMContentLoaded', () => {
    const sections = document.querySelectorAll('.headteacher .fade-in-section');
    sections.forEach(section => {
      observer.observe(section);
    });
  });
</script>