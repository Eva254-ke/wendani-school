---
// Headteacher Welcome Section
---

<section class="headteacher">
  <div class="headteacher__container">
    <div class="headteacher__grid">
      
      <!-- Photo -->
      <div class="headteacher__photo-wrapper fade-in-section">
        <div class="headteacher__photo-container">
          <img src="/images/leadership-music-class.jpeg" alt="Good News CEC teacher leading students in a music activity" class="headteacher__photo" />
        </div>
      </div>

      <!-- Content -->
      <div class="headteacher__content fade-in-section stagger-1">
        <span class="headteacher__badge">Message from Leadership</span>
        <div class="divider"></div>
        <h2 class="headteacher__title">Welcome to Good News Community Education Centre</h2>
        <blockquote class="headteacher__quote">
          "At Good News CEC, we believe every child has unique potential waiting to be discovered. Our commitment is to provide a nurturing, safe, and academically excellent environment where your child can grow into a confident, compassionate, and capable individual. We don't just teach curriculum—we build character, foster creativity, and prepare our students for a bright future."
        </blockquote>
        <div class="headteacher__signature">
          <p class="headteacher__name">Simon Kilonzo</p>
          <p class="headteacher__position">Headteacher, Good News CEC</p>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.addEventListener('DOMContentLoaded', () => {
    const sections = document.querySelectorAll('.headteacher .fade-in-section');
    sections.forEach(section => {
      observer.observe(section);
    });
  });
</script>
